#!/usr/bin/env bash
# aicode — launch OpenCode with $PWD as the ai_code MCP sandbox root.
#
# Usage:
#   cd <project-to-analyze>
#   aicode               # opens OpenCode TUI here, AICODE_ROOT=$PWD
#   aicode <args...>     # extra args are forwarded to `opencode`
#
# Override the auto-detected root:
#   AICODE_ROOT=/some/other/path aicode
#
# Designed to mirror the `claude` UX: cd into a project, run one command,
# done. No per-project edits to opencode.json required.

set -euo pipefail

resolve_aicode_home() {
  local source="${BASH_SOURCE[0]}"
  local dir

  while [ -h "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd -P)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done

  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd -P
}

CODETRAIL_HOME="$(resolve_aicode_home)" || {
  echo "[aicode] cannot resolve CodeTrail checkout path" >&2
  exit 2
}

# Allow explicit override via env, else use cwd (canonicalised).
if [ -n "${AICODE_ROOT:-}" ]; then
  ROOT="$AICODE_ROOT"
else
  ROOT="$(pwd -P)"
fi

# Resolve to absolute, canonical path (handles symlinks, ~, etc.).
ROOT="$(cd "$ROOT" 2>/dev/null && pwd -P)" || {
  echo "[aicode] root is not a readable directory: $ROOT" >&2
  exit 2
}

# Refuse roots that are almost certainly a mistake — these would expose
# the entire home / filesystem to the MCP sandbox.
case "$ROOT" in
  /)
    echo "[aicode] refusing AICODE_ROOT=/ (would expose entire filesystem)" >&2
    exit 2
    ;;
  "$HOME")
    echo "[aicode] refusing AICODE_ROOT=\$HOME ($HOME)" >&2
    echo "         cd into a specific project directory first." >&2
    exit 2
    ;;
esac

resolve_opencode_mcp_root() {
  if command -v git >/dev/null 2>&1; then
    git rev-parse --show-toplevel 2>/dev/null && return
  fi
  pwd -P
}

OPENCODE_MCP_ROOT="$(resolve_opencode_mcp_root)" || {
  echo "[aicode] cannot resolve OpenCode MCP wrapper root" >&2
  exit 2
}

prepare_opencode_mcp_wrapper() {
  local opencode_dir="$OPENCODE_MCP_ROOT/.opencode"
  local wrapper="$opencode_dir/run-codetrail-mcp"
  local tmp="$wrapper.tmp.$$"

  mkdir -p "$opencode_dir" || {
    echo "[aicode] cannot create $opencode_dir for the OpenCode MCP wrapper" >&2
    exit 2
  }

  if [ -e "$wrapper" ] && ! grep -q "generated by CodeTrail aicode" "$wrapper" 2>/dev/null; then
    if [ ! -x "$wrapper" ]; then
      echo "[aicode] WARNING: custom MCP wrapper exists but is not executable: $wrapper" >&2
    fi
    return
  fi

  cat > "$tmp" <<EOF
#!/usr/bin/env bash
# generated by CodeTrail aicode; safe to regenerate
set -euo pipefail

if [ -z "\${AICODE_ROOT:-}" ]; then
  AICODE_ROOT="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")/.." && pwd -P)"
  export AICODE_ROOT
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$CODETRAIL_HOME/mcp_server.py"
fi

exec python "$CODETRAIL_HOME/mcp_server.py"
EOF
  chmod 700 "$tmp"
  mv "$tmp" "$wrapper"
}

prepare_opencode_mcp_wrapper

if ! command -v opencode >/dev/null 2>&1; then
  echo "[aicode] 'opencode' not found in PATH — install with: npm install -g opencode-ai" >&2
  exit 127
fi

if command -v python3 >/dev/null 2>&1; then
  PYBIN=python3
elif command -v python >/dev/null 2>&1; then
  PYBIN=python
else
  PYBIN=""
fi

if [ -z "$PYBIN" ]; then
  echo "[aicode] python3/python not found in PATH — required for main-model resolution and ctx safety check." >&2
  exit 2
fi

# 主模型解析:env > -m/--model arg > ~/.config/opencode/opencode.json。
# 三個都找不到、是 placeholder、或被指到非 Ollama provider 時, resolve_main_model.py
# 會印 fail-loud 訊息到 stderr 並 exit 2。CodeTrail 不內建 / 不 fallback 任何
# 預設主模型 — 使用者必須先選一顆 Ollama 模型。
if ! RESOLVED_MAIN_MODEL="$("$PYBIN" "$CODETRAIL_HOME/scripts/resolve_main_model.py" "$@")"; then
  exit 2
fi
# resolve_main_model.py 已經剝掉 `ollama/` prefix, 這裡拿到的是 bare model name。
# 把它寫回 AICODE_MODEL, 讓 ctx_safety_check / mcp_server / 子行程拿到同一顆。
export AICODE_MODEL="$RESOLVED_MAIN_MODEL"

# Predict VRAM offload BEFORE we exec opencode. ctx_safety_check.py exits 2
# when the requested ctx cap (AICODE_DYNAMIC_NUM_CTX_MAX, default 65536) won't
# fit alongside model weights on the visible GPU. It prints concrete remedies
# (lower the cap, or AICODE_ACCEPT_CTX_RISK=1) so this is fail-loud — we don't
# silently clamp anything. UNKNOWN cases (no nvidia-smi, remote Ollama,
# unfamiliar model arch) exit 0 with a warning, so this won't block CI or
# remote-GPU setups.
if [ -f "$CODETRAIL_HOME/scripts/ctx_safety_check.py" ]; then
  if ! "$PYBIN" "$CODETRAIL_HOME/scripts/ctx_safety_check.py"; then
    echo "[aicode] ctx safety check refused to start (see [ctx-safety] above)." >&2
    exit 2
  fi
fi

export AICODE_ROOT="$ROOT"
echo "[aicode] AICODE_ROOT=$AICODE_ROOT"

# Surface the two-context-pipeline distinction so users know which knob
# controls what. AICODE_NUM_CTX only affects CodeTrail-internal Ollama
# native /api/chat | /api/generate calls (agent loop, RAG-related prompts).
# OpenCode TUI uses Ollama /v1 (OpenAI-compatible), whose effective context
# is determined by Ollama's OLLAMA_CONTEXT_LENGTH server setting + the
# OpenCode model limit.context value — neither of which AICODE_NUM_CTX
# can override.
echo "[aicode] AICODE_MODEL=${AICODE_MODEL}"
if [ -n "${AICODE_NUM_CTX:-}" ]; then
  echo "[aicode] AICODE_NUM_CTX=${AICODE_NUM_CTX} (僅在 dynamic 關閉時當 fallback 上限;dynamic 開啟時不影響 per-call ctx)"
fi
if [ -n "${AICODE_DYNAMIC_NUM_CTX_MAX:-}" ]; then
  echo "[aicode] AICODE_DYNAMIC_NUM_CTX_MAX=${AICODE_DYNAMIC_NUM_CTX_MAX} (dynamic 模式真正生效的 per-call ctx 上限)"
fi
if [ -n "${AICODE_RESERVED_OUTPUT_TOKENS:-}" ]; then
  echo "[aicode] AICODE_RESERVED_OUTPUT_TOKENS=${AICODE_RESERVED_OUTPUT_TOKENS}"
fi
if [ -n "${OLLAMA_CONTEXT_LENGTH:-}" ]; then
  echo "[aicode] OLLAMA_CONTEXT_LENGTH=${OLLAMA_CONTEXT_LENGTH} (server-side, affects OpenCode TUI /v1)"
fi
echo "[aicode] NOTE: 要調 CodeTrail native Ollama call 的 per-call ctx 上限,改 AICODE_DYNAMIC_NUM_CTX_MAX。"
echo "         OpenCode TUI 走 /v1,context 由 model limit.context + OLLAMA_CONTEXT_LENGTH 決定。"
echo "         Check loaded model size/ctx with: ollama ps"
echo "         CodeTrail context overflow attempts are logged to .codetrail/context_metrics.jsonl"

# Pitfall warning: /models in TUI silently desyncs from MCP server's background
# model. There's no MCP hook to propagate the switch, so RAG/strict tools keep
# using AICODE_MODEL while the conversation uses something else — Ollama ends
# up swapping two models in/out of VRAM, latency spikes, and the user has no
# idea why. Surface this once at launch so non-experts don't fall into it.
echo "[aicode] TIP: 換模型請退出後改 AICODE_MODEL 再重新啟動 aicode。"
echo "         在 TUI 內按 /models 只會換對話那顆,背景 RAG / query_knowledge_strict"
echo "         仍會用 AICODE_MODEL=${AICODE_MODEL},兩邊不會自動同步。"

# Point new users at the health check so they don't have to discover it via README.
echo "[aicode] TIP: 設定有疑慮時可跑 \`python scripts/doctor.py\` 做健檢。"

# 把解析後的 bare AICODE_MODEL 轉成 OpenCode 認得的 ollama/<MODEL> 形式,
# 自動把 --model 加進 opencode args, 讓 TUI 對話模型跟 MCP server 後台用同一顆。
# 若使用者命令列已經帶了 -m / --model, 不重複覆寫。
EXTRA_OPENCODE_ARGS=()
USER_PASSED_MODEL=0
for arg in "$@"; do
  case "$arg" in
    -m|--model|-m=*|--model=*) USER_PASSED_MODEL=1; break ;;
  esac
done

if [ "$USER_PASSED_MODEL" -eq 0 ]; then
  # AICODE_MODEL 在 resolve_main_model.py 已經 strip 掉 `ollama/` prefix,
  # 一定是 bare form (可能含 namespace slash, 例如 `some-org/foo:bar`)。
  # 對 OpenCode 一律補回 `ollama/` 前綴 — 不要用 `*/*` 判斷, 因為 Ollama 自己
  # 的 namespace 也含 slash 但仍需要 `ollama/` provider prefix。
  OC_MODEL="ollama/$AICODE_MODEL"
  EXTRA_OPENCODE_ARGS+=(--model "$OC_MODEL")
  echo "[aicode] OpenCode --model=$OC_MODEL"
fi

exec opencode ${EXTRA_OPENCODE_ARGS[@]+"${EXTRA_OPENCODE_ARGS[@]}"} "$@"
