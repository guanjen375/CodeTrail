#!/usr/bin/env bash
# aicode — launch OpenCode with $PWD as the ai_code MCP sandbox root.
#
# Usage:
#   cd <project-to-analyze>
#   aicode               # opens OpenCode TUI here, AICODE_ROOT=$PWD
#   aicode <args...>     # extra args are forwarded to `opencode`
#
# Override the auto-detected root:
#   AICODE_ROOT=/some/other/path aicode
#
# Designed to mirror the `claude` UX: cd into a project, run one command,
# done. No per-project edits to opencode.json required.

set -euo pipefail

# Allow explicit override via env, else use cwd (canonicalised).
if [ -n "${AICODE_ROOT:-}" ]; then
  ROOT="$AICODE_ROOT"
else
  ROOT="$(pwd -P)"
fi

# Resolve to absolute, canonical path (handles symlinks, ~, etc.).
ROOT="$(cd "$ROOT" 2>/dev/null && pwd -P)" || {
  echo "[aicode] root is not a readable directory: $ROOT" >&2
  exit 2
}

# Refuse roots that are almost certainly a mistake — these would expose
# the entire home / filesystem to the MCP sandbox.
case "$ROOT" in
  /)
    echo "[aicode] refusing AICODE_ROOT=/ (would expose entire filesystem)" >&2
    exit 2
    ;;
  "$HOME")
    echo "[aicode] refusing AICODE_ROOT=\$HOME ($HOME)" >&2
    echo "         cd into a specific project directory first." >&2
    exit 2
    ;;
esac

if ! command -v opencode >/dev/null 2>&1; then
  echo "[aicode] 'opencode' not found in PATH — install with: npm install -g opencode-ai" >&2
  exit 127
fi

export AICODE_ROOT="$ROOT"
echo "[aicode] AICODE_ROOT=$AICODE_ROOT"

# Surface the two-context-pipeline distinction so users know which knob
# controls what. AICODE_NUM_CTX only affects CodeTrail-internal Ollama
# native /api/chat | /api/generate calls (agent loop, RAG-related prompts).
# OpenCode TUI uses Ollama /v1 (OpenAI-compatible), whose effective context
# is determined by Ollama's OLLAMA_CONTEXT_LENGTH server setting + the
# OpenCode model limit.context value — neither of which AICODE_NUM_CTX
# can override.
if [ -n "${AICODE_MODEL:-}" ]; then
  echo "[aicode] AICODE_MODEL=${AICODE_MODEL}"
fi
if [ -n "${AICODE_NUM_CTX:-}" ]; then
  echo "[aicode] AICODE_NUM_CTX=${AICODE_NUM_CTX} (僅在 dynamic 關閉時當 fallback 上限;dynamic 開啟時不影響 per-call ctx)"
fi
if [ -n "${AICODE_DYNAMIC_NUM_CTX_MAX:-}" ]; then
  echo "[aicode] AICODE_DYNAMIC_NUM_CTX_MAX=${AICODE_DYNAMIC_NUM_CTX_MAX} (dynamic 模式真正生效的 per-call ctx 上限)"
fi
if [ -n "${AICODE_RESERVED_OUTPUT_TOKENS:-}" ]; then
  echo "[aicode] AICODE_RESERVED_OUTPUT_TOKENS=${AICODE_RESERVED_OUTPUT_TOKENS}"
fi
if [ -n "${OLLAMA_CONTEXT_LENGTH:-}" ]; then
  echo "[aicode] OLLAMA_CONTEXT_LENGTH=${OLLAMA_CONTEXT_LENGTH} (server-side, affects OpenCode TUI /v1)"
fi
echo "[aicode] NOTE: 要調 CodeTrail native Ollama call 的 per-call ctx 上限,改 AICODE_DYNAMIC_NUM_CTX_MAX。"
echo "         OpenCode TUI 走 /v1,context 由 model limit.context + OLLAMA_CONTEXT_LENGTH 決定。"
echo "         Check loaded model size/ctx with: ollama ps"
echo "         CodeTrail context overflow attempts are logged to .codetrail/context_metrics.jsonl"

# Pitfall warning: /models in TUI silently desyncs from MCP server's background
# model. There's no MCP hook to propagate the switch, so RAG/strict tools keep
# using AICODE_MODEL while the conversation uses something else — Ollama ends
# up swapping two models in/out of VRAM, latency spikes, and the user has no
# idea why. Surface this once at launch so non-experts don't fall into it.
echo "[aicode] TIP: 換模型請退出後改 AICODE_MODEL 再重新啟動 aicode。"
echo "         在 TUI 內按 /models 只會換對話那顆,背景 RAG / query_knowledge_strict"
echo "         仍會用 AICODE_MODEL=${AICODE_MODEL:-<default>},兩邊不會自動同步。"

# Point new users at the health check so they don't have to discover it via README.
echo "[aicode] TIP: 設定有疑慮時可跑 \`python scripts/doctor.py\` 做健檢。"

# If AICODE_MODEL is set, propagate it to OpenCode's --model flag so the
# TUI conversation defaults to the same model the MCP server uses. Users
# can still override with an explicit -m/--model in their own args.
EXTRA_OPENCODE_ARGS=()
USER_PASSED_MODEL=0
for arg in "$@"; do
  case "$arg" in
    -m|--model|-m=*|--model=*) USER_PASSED_MODEL=1; break ;;
  esac
done

if [ -n "${AICODE_MODEL:-}" ] && [ "$USER_PASSED_MODEL" -eq 0 ]; then
  # AICODE_MODEL may be bare ("qwen3.6:35b-a3b-q4_K_M") or already
  # provider-qualified ("ollama/qwen3.6:..."). Only prepend "ollama/"
  # when the value has no provider prefix.
  case "$AICODE_MODEL" in
    */*) OC_MODEL="$AICODE_MODEL" ;;
    *)   OC_MODEL="ollama/$AICODE_MODEL" ;;
  esac
  EXTRA_OPENCODE_ARGS+=(--model "$OC_MODEL")
  echo "[aicode] OpenCode --model=$OC_MODEL"
fi

exec opencode ${EXTRA_OPENCODE_ARGS[@]+"${EXTRA_OPENCODE_ARGS[@]}"} "$@"
