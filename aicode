#!/usr/bin/env bash
# aicode — launch OpenCode with $PWD as the ai_code MCP sandbox root.
#
# Usage:
#   cd <project-to-analyze>
#   aicode               # opens OpenCode TUI here, AICODE_ROOT=$PWD
#   aicode <args...>     # extra args are forwarded to `opencode`
#
# Override the auto-detected root:
#   AICODE_ROOT=/some/other/path aicode
#
# Designed to mirror the `claude` UX: cd into a project, run one command,
# done. No per-project edits to opencode.json required.

set -euo pipefail

# Allow explicit override via env, else use cwd (canonicalised).
if [ -n "${AICODE_ROOT:-}" ]; then
  ROOT="$AICODE_ROOT"
else
  ROOT="$(pwd -P)"
fi

# Resolve to absolute, canonical path (handles symlinks, ~, etc.).
ROOT="$(cd "$ROOT" 2>/dev/null && pwd -P)" || {
  echo "[aicode] root is not a readable directory: $ROOT" >&2
  exit 2
}

# Refuse roots that are almost certainly a mistake — these would expose
# the entire home / filesystem to the MCP sandbox.
case "$ROOT" in
  /)
    echo "[aicode] refusing AICODE_ROOT=/ (would expose entire filesystem)" >&2
    exit 2
    ;;
  "$HOME")
    echo "[aicode] refusing AICODE_ROOT=\$HOME ($HOME)" >&2
    echo "         cd into a specific project directory first." >&2
    exit 2
    ;;
esac

if ! command -v opencode >/dev/null 2>&1; then
  echo "[aicode] 'opencode' not found in PATH — install with: npm install -g opencode-ai" >&2
  exit 127
fi

export AICODE_ROOT="$ROOT"
echo "[aicode] AICODE_ROOT=$AICODE_ROOT"

# If AICODE_MODEL is set, propagate it to OpenCode's --model flag so the
# TUI conversation defaults to the same model the MCP server uses. Users
# can still override with an explicit -m/--model in their own args.
EXTRA_OPENCODE_ARGS=()
USER_PASSED_MODEL=0
for arg in "$@"; do
  case "$arg" in
    -m|--model|-m=*|--model=*) USER_PASSED_MODEL=1; break ;;
  esac
done

if [ -n "${AICODE_MODEL:-}" ] && [ "$USER_PASSED_MODEL" -eq 0 ]; then
  # AICODE_MODEL may be bare ("qwen3.6:35b-a3b-q4_K_M") or already
  # provider-qualified ("ollama/qwen3.6:..."). Only prepend "ollama/"
  # when the value has no provider prefix.
  case "$AICODE_MODEL" in
    */*) OC_MODEL="$AICODE_MODEL" ;;
    *)   OC_MODEL="ollama/$AICODE_MODEL" ;;
  esac
  EXTRA_OPENCODE_ARGS+=(--model "$OC_MODEL")
  echo "[aicode] OpenCode --model=$OC_MODEL"
fi

exec opencode ${EXTRA_OPENCODE_ARGS[@]+"${EXTRA_OPENCODE_ARGS[@]}"} "$@"
