#!/usr/bin/env bash
# aicode — launch OpenCode with $PWD as the ai_code MCP sandbox root.
#
# Usage:
#   cd <project-to-analyze>
#   aicode               # opens OpenCode TUI here, AICODE_ROOT=$PWD
#   aicode <args...>     # extra args are forwarded to `opencode`
#
# Override the auto-detected root:
#   AICODE_ROOT=/some/other/path aicode
#
# Designed as a one-command CLI: cd into a project, run one command, done.
# No per-project edits to opencode.json required.

set -euo pipefail

resolve_aicode_home() {
  local source="${BASH_SOURCE[0]}"
  local dir

  while [ -h "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd -P)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done

  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd -P
}

CODETRAIL_HOME="$(resolve_aicode_home)" || {
  echo "[aicode] cannot resolve CodeTrail checkout path" >&2
  exit 2
}

# Allow explicit override via env, else use cwd (canonicalised).
if [ -n "${AICODE_ROOT:-}" ]; then
  ROOT="$AICODE_ROOT"
else
  ROOT="$(pwd -P)"
fi

# Resolve to absolute, canonical path (handles symlinks, ~, etc.).
ROOT="$(cd "$ROOT" 2>/dev/null && pwd -P)" || {
  echo "[aicode] root is not a readable directory: $ROOT" >&2
  exit 2
}

# Refuse roots that are almost certainly a mistake — these would expose
# the entire home / filesystem to the MCP sandbox.
case "$ROOT" in
  /)
    echo "[aicode] refusing AICODE_ROOT=/ (would expose entire filesystem)" >&2
    exit 2
    ;;
  "$HOME")
    echo "[aicode] refusing AICODE_ROOT=\$HOME ($HOME)" >&2
    echo "         cd into a specific project directory first." >&2
    exit 2
    ;;
esac

resolve_opencode_mcp_root() {
  if command -v git >/dev/null 2>&1; then
    git rev-parse --show-toplevel 2>/dev/null && return
  fi
  pwd -P
}

OPENCODE_MCP_ROOT="$(resolve_opencode_mcp_root)" || {
  echo "[aicode] cannot resolve OpenCode MCP wrapper root" >&2
  exit 2
}

prepare_opencode_mcp_wrapper() {
  local opencode_dir="$OPENCODE_MCP_ROOT/.opencode"
  local wrapper="$opencode_dir/run-codetrail-mcp"
  local tmp="$wrapper.tmp.$$"

  mkdir -p "$opencode_dir" || {
    echo "[aicode] cannot create $opencode_dir for the OpenCode MCP wrapper" >&2
    exit 2
  }

  if [ -e "$wrapper" ] && ! grep -q "generated by CodeTrail aicode" "$wrapper" 2>/dev/null; then
    if [ ! -x "$wrapper" ]; then
      echo "[aicode] WARNING: custom MCP wrapper exists but is not executable: $wrapper" >&2
    fi
    return
  fi

  cat > "$tmp" <<EOF
#!/usr/bin/env bash
# generated by CodeTrail aicode; safe to regenerate
set -euo pipefail

if [ -z "\${AICODE_ROOT:-}" ]; then
  AICODE_ROOT="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")/.." && pwd -P)"
  export AICODE_ROOT
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$CODETRAIL_HOME/mcp_server.py"
fi

exec python "$CODETRAIL_HOME/mcp_server.py"
EOF
  chmod 700 "$tmp"
  mv "$tmp" "$wrapper"
}

prepare_opencode_mcp_wrapper

if ! command -v opencode >/dev/null 2>&1; then
  echo "[aicode] 'opencode' not found in PATH — install with: npm install -g opencode-ai" >&2
  exit 127
fi

if command -v python3 >/dev/null 2>&1; then
  PYBIN=python3
elif command -v python >/dev/null 2>&1; then
  PYBIN=python
else
  PYBIN=""
fi

if [ -z "$PYBIN" ]; then
  echo "[aicode] python3/python not found in PATH — required for main-model resolution and ctx safety check." >&2
  exit 2
fi

# 主模型解析:env > -m/--model arg > OPENCODE_CONFIG / ~/.config/opencode/opencode.json。
# 三個都找不到、是 placeholder、或被指到外部 provider (openai/、ollama/ 等) 時,
# resolve_main_model.py 會印 fail-loud 訊息到 stderr 並 exit 2。CodeTrail 不內建 /
# 不 fallback 任何預設主模型 — 使用者必須先下載一顆 GGUF 並啟動 llama-server。
if ! RESOLVED_MAIN_MODEL="$("$PYBIN" "$CODETRAIL_HOME/scripts/resolve_main_model.py" "$@")"; then
  exit 2
fi
# resolve_main_model.py 已經 strip 掉 custom provider prefix, 這裡拿到的是 bare
# model name (或 GGUF 路徑)。把它寫回 AICODE_MODEL, 讓 ctx_safety_check /
# mcp_server / 子行程拿到同一顆。
export AICODE_MODEL="$RESOLVED_MAIN_MODEL"

# Verify main llama-server's actual n_ctx is big enough for our budget BEFORE
# we exec opencode. ctx_safety_check.py reads /props from the server (8080 by
# default) and exits 2 if requested ctx (AICODE_DYNAMIC_NUM_CTX_MAX, default
# 65536) > server n_ctx. It prints concrete remedies (lower the cap, restart
# server with bigger -c, AICODE_ACCEPT_CTX_RISK=1) so this is fail-loud — we
# don't silently truncate. UNKNOWN cases (server not started, remote server
# unreachable) exit 0 with a warning, so this won't block CI or remote setups.
if [ -f "$CODETRAIL_HOME/scripts/ctx_safety_check.py" ]; then
  if ! "$PYBIN" "$CODETRAIL_HOME/scripts/ctx_safety_check.py"; then
    echo "[aicode] ctx safety check refused to start (see [ctx-safety] above)." >&2
    exit 2
  fi
fi

export AICODE_ROOT="$ROOT"
echo "[aicode] AICODE_ROOT=$AICODE_ROOT"

# Surface the two-context-pipeline distinction so users know which knob
# controls what. AICODE_DYNAMIC_NUM_CTX_MAX only affects CodeTrail-internal
# llama-server calls (agent loop, RAG-related prompts, embedding, reranker).
# OpenCode TUI uses /v1/chat/completions against the same main llama-server,
# whose effective context is determined by the server's `-c <N>` flag + the
# OpenCode model limit.context value — neither of which AICODE_DYNAMIC_NUM_CTX_MAX
# can override.
echo "[aicode] AICODE_MODEL=${AICODE_MODEL}"
if [ -n "${AICODE_NUM_CTX:-}" ]; then
  echo "[aicode] AICODE_NUM_CTX=${AICODE_NUM_CTX} (僅在 dynamic 關閉時當 fallback 上限;dynamic 開啟時不影響 per-call ctx)"
fi
if [ -n "${AICODE_DYNAMIC_NUM_CTX_MAX:-}" ]; then
  echo "[aicode] AICODE_DYNAMIC_NUM_CTX_MAX=${AICODE_DYNAMIC_NUM_CTX_MAX} (dynamic 模式真正生效的 per-call ctx 上限)"
fi
if [ -n "${AICODE_RESERVED_OUTPUT_TOKENS:-}" ]; then
  echo "[aicode] AICODE_RESERVED_OUTPUT_TOKENS=${AICODE_RESERVED_OUTPUT_TOKENS}"
fi
if [ -n "${AICODE_LLAMA_BASE_URL:-}" ]; then
  echo "[aicode] AICODE_LLAMA_BASE_URL=${AICODE_LLAMA_BASE_URL} (主 LLM server)"
fi
echo "[aicode] NOTE: 要調 per-call ctx 上限,改 AICODE_DYNAMIC_NUM_CTX_MAX (受 server -c 限制)。"
echo "         llama-server 啟動時 -c <N> 是真實 ctx 上限,改了要重啟 server。"
echo "         Check loaded model with: curl -s \${AICODE_LLAMA_BASE_URL:-http://localhost:8080}/props"
echo "         CodeTrail context overflow attempts are logged to .codetrail/context_metrics.jsonl"

# Pitfall warning: /models in TUI 跟 CodeTrail MCP 的 AICODE_MODEL 是兩條獨立
# 設定。換模型靠重啟 server (load 新 GGUF) + 重啟 aicode wrapper。
echo "[aicode] TIP: 換模型請先停掉 llama-server, 換 GGUF 重啟, 再改 AICODE_MODEL 重啟 aicode。"
echo "         在 TUI 內按 /models 只會切 OpenCode 那邊的 model id,不會 reload server,"
echo "         也不會通知 CodeTrail MCP — 兩邊不同步會錯亂。"

# Point new users at the health check so they don't have to discover it via README.
echo "[aicode] TIP: 設定有疑慮時可跑 \`AICODE_MODEL=${AICODE_MODEL} python scripts/doctor.py\` 做健檢。"

# OpenCode 那邊吃 <custom-provider>/<model> 形式的 model id (provider 名由使用者
# 在 opencode.json 自己取)。CodeTrail wrapper 沒辦法 / 也不該替使用者決定 provider
# 取名是什麼,所以這裡:
#   - 若使用者傳了 -m / --model:原樣轉發給 opencode (使用者負責格式正確)
#   - 若沒傳:不主動加 --model;讓 opencode 自己讀 opencode.json 的 "model" 欄位
# AICODE_MODEL (bare name) 仍用於 CodeTrail MCP 本體, 跟 OpenCode TUI 顯示的
# 可能形式不同但語意一致 (provider/ 後面那段)。
OPENCODE_ARGS=()
USER_PASSED_MODEL=0
USER_MODEL_VALUE=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    -m|--model)
      USER_PASSED_MODEL=1
      flag="$1"
      if [ "$#" -lt 2 ] || [[ "$2" == -* ]]; then
        echo "[aicode] $flag requires a model value." >&2
        exit 2
      fi
      USER_MODEL_VALUE="$2"
      OPENCODE_ARGS+=("$flag" "$2")
      shift 2
      ;;
    -m=*)
      USER_PASSED_MODEL=1
      val="${1#-m=}"
      if [ -z "$val" ]; then
        echo "[aicode] -m requires a model value." >&2
        exit 2
      fi
      USER_MODEL_VALUE="$val"
      OPENCODE_ARGS+=("$1")
      shift
      ;;
    --model=*)
      USER_PASSED_MODEL=1
      val="${1#--model=}"
      if [ -z "$val" ]; then
        echo "[aicode] --model requires a model value." >&2
        exit 2
      fi
      USER_MODEL_VALUE="$val"
      OPENCODE_ARGS+=("$1")
      shift
      ;;
    *)
      OPENCODE_ARGS+=("$1")
      shift
      ;;
  esac
done

if [ "$USER_PASSED_MODEL" -eq 1 ]; then
  echo "[aicode] OpenCode --model=$USER_MODEL_VALUE (使用者傳入,原樣轉發)"
else
  echo "[aicode] 沒有 -m;OpenCode 將自己讀 opencode.json 的 \"model\" 欄位。"
  echo "         若你要明確指定 provider,請用 -m <provider>/<model> 或在 opencode.json 設好。"
fi

exec opencode "${OPENCODE_ARGS[@]}"
